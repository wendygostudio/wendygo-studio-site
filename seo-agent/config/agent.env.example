# ============================================================
# Wendygo Studio Agent — Configuración
# ============================================================
# Copia este archivo y rellena los valores reales.
# NUNCA commitees este archivo al repo.
# ============================================================

# ── Anthropic API ──────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-CAMBIAR-POR-TU-KEY-REAL"

# Modelo a usar (sonnet es más barato, opus para tareas críticas)
CLAUDE_MODEL="claude-sonnet-4-6"

# ── Límites de seguridad ──────────────────────────────────
MAX_TOKENS_PER_RUN=50000
MAX_DAILY_COST_EUR=5

# ── Directorio del sitio web ──────────────────────────────
SITE_DIR="$HOME/wendygo-site"

# ── Google Search Console (opcional) ──────────────────────
# URL del sitio como aparece en GSC (con o sin trailing slash)
GSC_SITE_URL=""
# Ejemplo: GSC_SITE_URL="https://wendygo.studio/"

# ── Plausible Analytics (opcional, alternativa a Google) ──
PLAUSIBLE_API_KEY=""
PLAUSIBLE_SITE_ID=""
# Si usas self-hosted:
# PLAUSIBLE_URL="https://tu-plausible.example.com"

# ── Twitter/X API (opcional) ──────────────────────────────
TWITTER_API_KEY=""
TWITTER_API_SECRET=""
TWITTER_ACCESS_TOKEN=""
TWITTER_ACCESS_SECRET=""

# ── Git (para auto-deploy) ────────────────────────────────
GIT_AUTHOR_NAME="Wendygo Agent"
GIT_AUTHOR_EMAIL="agent@wendygo.studio"
GIT_COMMITTER_NAME="Wendygo Agent"
GIT_COMMITTER_EMAIL="agent@wendygo.studio"
